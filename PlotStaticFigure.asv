figure();
for i = 1:9
    subplot(3,5, i);
    rec_img = inv_solve(inv2d, datas(i+30, :).', baselines(i+30, :).');
    % f = show_fem(rec_img, [1 0 0]);
    scattereidors(rec_img);
    hold on
    scatter(touches(i+30, 1), touches(i+30, 2), 50, 'm', 'filled');
end

function scattereidors(rec_img)
    positions = zeros([length(rec_img.elem_data), 2]);
    for i = 1:length(rec_img.elem_data)
        positions(i, :) = mean(rec_img.fwd_model.nodes(rec_img.fwd_model.elems(i, :), :));
    end

    colormap hot
    scatter(positions(:, 1), positions(:,2), 30, rec_img.elem_data, 'filled');
end